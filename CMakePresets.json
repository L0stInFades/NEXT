{
  "version": 2,
  "configurePresets": [
    {
      "name": "terminal-dev",
      "displayName": "Terminal / HackOps development",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/out/build/terminal-dev",
      "cacheVariables": {
        "BUILD_RENDERER": "OFF",
        "BUILD_TOOLS": "ON",
        "BUILD_EDITOR": "OFF",
        "BUILD_GAME": "OFF",
        "BUILD_TESTS": "OFF",
        "BUILD_TERMINAL": "ON"
      }
    },
    {
      "name": "windows-dx12-dev",
      "displayName": "Windows DX12 Song/editor development",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/out/build/windows-dx12-dev",
      "cacheVariables": {
        "BUILD_RENDERER": "ON",
        "BUILD_TOOLS": "ON",
        "BUILD_EDITOR": "ON",
        "BUILD_GAME": "ON",
        "BUILD_TESTS": "ON",
        "BUILD_TERMINAL": "ON"
      }
    },
    {
      "name": "macos-metal-dev",
      "displayName": "macOS Metal Song development",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/out/build/macos-metal-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_RENDERER": "ON",
        "BUILD_TOOLS": "OFF",
        "BUILD_EDITOR": "OFF",
        "BUILD_GAME": "ON",
        "BUILD_TESTS": "OFF",
        "BUILD_TERMINAL": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "terminal-dev",
      "configurePreset": "terminal-dev",
      "targets": [
        "next_nvim_surface_probe"
      ]
    },
    {
      "name": "windows-dx12-dev",
      "configurePreset": "windows-dx12-dev",
      "configuration": "Debug"
    },
    {
      "name": "macos-metal-dev",
      "configurePreset": "macos-metal-dev",
      "targets": [
        "song_demo"
      ]
    }
  ]
}
